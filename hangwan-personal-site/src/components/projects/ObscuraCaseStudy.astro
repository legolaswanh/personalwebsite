---
import CaseStudyMedia from './CaseStudyMedia.astro';
import CaseStudyVideo from './CaseStudyVideo.astro';
import {
  obscuraCaseStudyImages,
  obscuraNarrativeDesignImages,
} from '../../data/obscuraCaseStudy';
import { aboutContactIcons } from '../../data/aboutAssets';
import { contactEmail, socialLinks } from '../../data/aboutContent';

const images = obscuraCaseStudyImages;

const backToChapterHref = '/?highlight=obscura#chapter-1';
---

<article class="scarlett-case-study obscura-case-study">
  <header class="scarlett-case-study__hero">
    <p class="scarlett-case-study__project-name">Obscura</p>
    <h1 class="scarlett-case-study__hero-title">
      A spatial puzzle game built around level structure, navigation, and environmental reasoning through <strong>spatial puzzle.</strong>
    </h1>
    <div class="scarlett-case-study__hero-split" data-unself-hero-split>
      <div class="scarlett-case-study__hero-copy" data-unself-hero-copy>
        <p class="scarlett-case-study__body">
          Players switch between masked and unmasked states to reshape the environment. Platforms, barriers, and routes appear or disappear, turning identity into the key to both navigation and progression.
        </p>
        <p class="scarlett-case-study__body">
          Obscura was created by a five-person team in 48 hours for Global Game Jam Gothenburg 2026 under the theme Mask. I contributed to ideation, level design, and development, with a focus on camera control.
        </p>
      </div>
      <figure class="scarlett-case-study__hero-media" data-unself-hero-media>
        <video
          class="scarlett-case-study__hero-video"
          src={images.hero}
          autoplay
          loop
          muted
          playsinline
          preload="metadata"
          aria-label="Obscura gameplay"
          data-unself-hero-img
        ></video>
      </figure>
    </div>
  </header>

  <section class="scarlett-case-study__section" aria-labelledby="obscura-inspiration">
    <p id="obscura-inspiration" class="scarlett-case-study__section-label">INSPIRATION</p>

    <div class="scarlett-case-study__text-block">
      <h2 class="scarlett-case-study__block-title">
        The Mask as Access
      </h2>
      <p class="scarlett-case-study__body">
        We treated the mask not only as a disguise, but as a condition for belonging. Wearing it allows the player to pass through the world, while gradually blurring the boundary between adaptation and identity.
      </p>
    </div>
  </section>

  <section class="scarlett-case-study__section" aria-labelledby="obscura-game-design">
    <p id="obscura-game-design" class="scarlett-case-study__section-label">GAME DESIGN</p>

    <div class="scarlett-case-study__stack">
      <div class="obscura-game-design__lead" data-obscura-lead>
        <CaseStudyVideo
          class="obscura-game-design__lead-video"
          src={images.gameDesignImage1}
          placeholder="Game design video 1"
        />

        <div class="obscura-game-design__lead-copy" data-obscura-lead-copy>
          <div class="scarlett-case-study__text-block">
            <h2 class="scarlett-case-study__block-title">
              Shifting Space Through Masks
            </h2>
            <p class="scarlett-case-study__body">
              Switching masks reconfigures platforms, obstacles, and routes within the same environment. Players compare different versions of the space and use their differences to construct a path forward.
            </p>
          </div>

          <div class="scarlett-case-study__text-block">
            <h2 class="scarlett-case-study__block-title">Learning Through Space</h2>
            <p class="scarlett-case-study__body">
              Each puzzle introduces a clearer relationship between masks and the environment. Through observation and experimentation, players gradually learn how each state changes the space and how those changes can be combined.
            </p>
          </div>
        </div>
      </div>

      <div class="obscura-game-design__block">
        <div class="scarlett-case-study__text-block">
          <h2 class="scarlett-case-study__block-title">Progress and Identity</h2>
          <p class="scarlett-case-study__body">
            Each mask creates a way forward, but also changes how the player sees and is seen. Spatial progression therefore reflects the game’s central tension between adapting to the world and preserving a sense of self.
          </p>
        </div>

        <div class="obscura-game-design__pair" data-obscura-pair>
          <CaseStudyVideo
            class="obscura-game-design__pair-video"
            src={images.gameDesignImage2}
            placeholder="Game design video 2"
          />
          <CaseStudyVideo
            class="obscura-game-design__pair-video"
            src={images.gameDesignImage3}
            placeholder="Game design video 3"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="scarlett-case-study__section" aria-labelledby="obscura-narrative-design">
    <p id="obscura-narrative-design" class="scarlett-case-study__section-label">
      NARRATIVE DESIGN
    </p>

    <div class="scarlett-case-study__text-block">
      <h2 class="scarlett-case-study__block-title">
        Finding the Self Behind the Mask
      </h2>
      <p class="scarlett-case-study__body">
        Each mask offers a different way through the world, but also distances the player from their original identity. As the environment shifts, the journey gradually becomes less about finding an exit and more about discovering what remains beneath the masks.
      </p>
    </div>

    <div class="obscura-narrative-design__gallery">
      {
        obscuraNarrativeDesignImages.map((image, index) => (
          <CaseStudyMedia
            class={`obscura-narrative-design__image obscura-narrative-design__image--${index + 1}`}
            src={image.src}
            alt=""
            placeholder={image.placeholder}
            aspectRatio="16 / 9"
          />
        ))
      }
    </div>
  </section>

  <section class="scarlett-case-study__section" aria-labelledby="obscura-gameplay">
    <p id="obscura-gameplay" class="scarlett-case-study__section-label">
      GAMEPLAY
    </p>

    <div class="scarlett-case-study__text-block">
      <h2 class="scarlett-case-study__block-title">
        Observe, Switch, and Navigate
      </h2>
      <p class="scarlett-case-study__body">
        Players explore compact 3D environments, switch masks, and solve puzzles by reading how the surrounding space changes. A route blocked in one state may become accessible in another, making each level a puzzle of perception and position.
      </p>
    </div>
  </section>


  <footer class="scarlett-case-study__footer">
    <a class="scarlett-case-study__back" href={backToChapterHref}>← Back to Chapter</a>

    <div class="scarlett-case-study__closing">
      <p class="scarlett-case-study__thanks">
        Thank you for exploring my world! If it resonates, I'd love to hear from you.
      </p>
      <div class="scarlett-case-study__credit">
        <span class="scarlett-case-study__name">Hang Wan</span>
        <span class="scarlett-case-study__credit-dot" aria-hidden="true">·</span>
        <span class="scarlett-case-study__role">Design Playful Experience</span>
        <span class="scarlett-case-study__credit-divider" aria-hidden="true"></span>
        <div class="scarlett-case-study__credit-links">
          <a
            class="scarlett-case-study__credit-link"
            href={`mailto:${contactEmail}`}
            aria-label="Email Hang Wan"
          >
            <img
              class="scarlett-case-study__credit-icon"
              src={aboutContactIcons.gmail}
              alt=""
              width="44"
              height="44"
              loading="lazy"
            />
          </a>
          <a
            class="scarlett-case-study__credit-link"
            href={socialLinks.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
          >
            <img
              class="scarlett-case-study__credit-icon"
              src={aboutContactIcons.linkedin}
              alt=""
              width="44"
              height="44"
              loading="lazy"
            />
          </a>
        </div>
      </div>
    </div>
  </footer>
</article>

<script>
  function initCaseStudyMedia() {
    document.querySelectorAll('[data-case-study-img]').forEach((img) => {
      if (!(img instanceof HTMLImageElement) || img.dataset.mediaBound === 'true') return;
      img.dataset.mediaBound = 'true';

      const markMissing = () => {
        const figure = img.closest('[data-case-study-media]');
        figure?.classList.add('is-missing');
      };

      img.addEventListener('error', markMissing);
      if (img.complete && img.naturalWidth === 0) markMissing();
    });

    document.querySelectorAll('[data-case-study-video]').forEach((video) => {
      if (!(video instanceof HTMLVideoElement) || video.dataset.mediaBound === 'true') return;
      video.dataset.mediaBound = 'true';

      const markMissing = () => {
        const figure = video.closest('[data-case-study-media]');
        figure?.classList.add('is-missing');
      };

      video.addEventListener('error', markMissing);
    });
  }

  initCaseStudyMedia();
  document.addEventListener('astro:page-load', initCaseStudyMedia);

  function syncObscuraGameDesignLayouts() {
    const mobileQuery = window.matchMedia('(max-width: 720px)');

    document.querySelectorAll('[data-obscura-lead]').forEach((lead) => {
      if (!(lead instanceof HTMLElement)) return;

      const copy = lead.querySelector('[data-obscura-lead-copy]');
      const media = lead.querySelector('.obscura-game-design__lead-video');
      const video = lead.querySelector('.obscura-game-design__lead-video video');

      if (!(copy instanceof HTMLElement) || !(media instanceof HTMLElement) || !(video instanceof HTMLVideoElement)) {
        return;
      }

      if (mobileQuery.matches) {
        media.style.height = '';
        media.style.width = '';
        media.style.maxWidth = '';
        video.style.height = '';
        video.style.width = '';
        video.style.maxWidth = '';
        return;
      }

      // Reset first so text can reclaim its column width before measuring height.
      media.style.maxWidth = '';
      media.style.width = '100%';
      media.style.height = '';
      video.style.maxWidth = '';
      video.style.width = '100%';
      video.style.height = 'auto';

      const copyHeight = Math.round(copy.getBoundingClientRect().height);
      if (copyHeight <= 0) return;

      media.style.height = `${copyHeight}px`;
      video.style.height = `${copyHeight}px`;
      video.style.width = '100%';
      video.style.objectFit = 'contain';
    });

    document.querySelectorAll('[data-obscura-pair]').forEach((pair) => {
      if (!(pair instanceof HTMLElement)) return;

      const mediaItems = Array.from(pair.querySelectorAll('.obscura-game-design__pair-video')).filter(
        (el) => el instanceof HTMLElement,
      );
      const videos = Array.from(pair.querySelectorAll('.obscura-game-design__pair-video video')).filter(
        (el) => el instanceof HTMLVideoElement,
      );

      if (mediaItems.length === 0 || videos.length === 0) return;

      if (mobileQuery.matches) {
        mediaItems.forEach((media) => {
          media.style.height = '';
        });
        videos.forEach((video) => {
          video.style.height = '';
          video.style.width = '';
        });
        return;
      }

      mediaItems.forEach((media) => {
        media.style.height = '';
      });
      videos.forEach((video) => {
        video.style.height = '';
        video.style.width = '100%';
      });

      const heights = videos
        .map((video) => Math.round(video.getBoundingClientRect().height))
        .filter((height) => height > 0);
      if (heights.length === 0) return;

      const targetHeight = Math.max(...heights);
      mediaItems.forEach((media) => {
        media.style.height = `${targetHeight}px`;
      });
      videos.forEach((video) => {
        video.style.height = `${targetHeight}px`;
        video.style.width = '100%';
      });
    });
  }

  function initObscuraGameDesignLayouts() {
    syncObscuraGameDesignLayouts();

    document.querySelectorAll('.obscura-game-design__lead-video video, .obscura-game-design__pair-video video').forEach((video) => {
      if (!(video instanceof HTMLVideoElement) || video.dataset.obscuraLayoutBound === 'true') return;
      video.dataset.obscuraLayoutBound = 'true';
      video.addEventListener('loadedmetadata', syncObscuraGameDesignLayouts);
    });
  }

  initObscuraGameDesignLayouts();
  window.addEventListener('resize', syncObscuraGameDesignLayouts);
  document.addEventListener('astro:page-load', () => {
    initObscuraGameDesignLayouts();
    requestAnimationFrame(syncObscuraGameDesignLayouts);
  });
</script>
