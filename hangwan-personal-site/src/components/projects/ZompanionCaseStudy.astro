---
import {
  zompanionCaseStudyImages,
  zompanionConceptImages,
  zompanionGameDevelopmentImages,
} from '../../data/zompanionCaseStudy';
import { aboutContactIcons } from '../../data/aboutAssets';
import { contactEmail, socialLinks } from '../../data/aboutContent';

const images = zompanionCaseStudyImages;

const backToChapterHref = '/?highlight=zompanion#chapter-1';
---

<article class="scarlett-case-study zompanion-case-study">
  <header class="scarlett-case-study__hero">
    <p class="scarlett-case-study__project-name">Zompanion</p>
    <h1 class="scarlett-case-study__hero-title">
      A playful supernatural adventure about companionship, forgotten souls, and <strong>finding warmth in the strange.</strong>
    </h1>
    <figure class="zompanion-hero-title-media">
      <img
        class="zompanion-hero-title-media__img"
        src={images.heroTitle}
        alt=""
        loading="eager"
        decoding="async"
        data-zompanion-hero-title-img
      />
    </figure>
    <div class="scarlett-case-study__hero-split" data-zompanion-hero-split>
      <figure class="scarlett-case-study__hero-media" data-zompanion-hero-media>
        <img
          class="scarlett-case-study__hero-img"
          src={images.hero}
          alt=""
          loading="eager"
          decoding="async"
          data-zompanion-hero-img
        />
      </figure>
      <div class="scarlett-case-study__hero-copy" data-zompanion-hero-copy>
        <p class="scarlett-case-study__body">
          Inspired by traditional Chinese ghost stories and jiangshi (zombie) culture, players explore a supernatural world, uncover buried objects and remains, and combine them into different zombie companions
        </p>
        <p class="scarlett-case-study__body">
          Zompanion was developed as a four-person course project. I was responsible for concept and gameplay design, game development (scene management, exploration and digging, dialogue, inventory), and parts of the interface design.
        </p>
      </div>
      <figure class="scarlett-case-study__hero-media scarlett-case-study__hero-media--gif" data-zompanion-hero-gif-media>
        <img
          class="scarlett-case-study__hero-gif"
          src={images.heroGif}
          alt=""
          loading="eager"
          decoding="async"
          data-zompanion-hero-gif
        />
      </figure>
    </div>
  </header>

  <section class="scarlett-case-study__section" aria-labelledby="zompanion-inspiration">
    <p id="zompanion-inspiration" class="scarlett-case-study__section-label">CONCEPT</p>

    <div class="zompanion-concept-row" data-zompanion-concept-row>
      <h2 class="scarlett-case-study__block-title zompanion-concept-row__title">
        Turning Monsters into <strong>Companions</strong>
      </h2>
      <div class="zompanion-concept-row__body" data-zompanion-concept-copy>
        <p class="scarlett-case-study__body">
          Rather than treating zombies as enemies, Zompanion reimagines them as companions created and cared for by the player.
        </p>
        <p class="scarlett-case-study__body">
          The project combines a playful tone with traditional supernatural imagery, presenting corpse collection and zombie assembly as strange but affectionate acts of companionship.
        </p>
      </div>
      <div class="zompanion-concept-images" data-zompanion-concept-images>
        {
          zompanionConceptImages.map((image) => (
            <figure class="zompanion-concept-images__item">
              <img
                class="zompanion-concept-images__img"
                src={image.src}
                alt=""
                loading="lazy"
                decoding="async"
                data-zompanion-concept-img
                data-placeholder={image.placeholder}
              />
            </figure>
          ))
        }
      </div>
    </div>
  </section>

  <section class="scarlett-case-study__section" aria-labelledby="zompanion-game-design">
    <p id="zompanion-game-design" class="scarlett-case-study__section-label">GAME DESIGN</p>

    <div class="zompanion-game-design-row" data-zompanion-game-design-row>
      <div class="zompanion-game-design-copy" data-zompanion-game-design-copy>
        <div class="scarlett-case-study__text-block">
          <h2 class="scarlett-case-study__block-title">
            Explore, Dig, and Assemble
          </h2>
          <p class="scarlett-case-study__body">
            Players explore different areas, uncover hidden body parts and ritual objects, and use their discoveries to assemble new zombie companions. Digging transforms ordinary environments into spaces of discovery, connecting exploration, collection, and character creation.
          </p>
          <p class="scarlett-case-study__body">
            Once created, the zombie could follow the player and support later exploration, connecting collection with companion progression.
          </p>
        </div>

        <div class="scarlett-case-study__text-block">
          <h2 class="scarlett-case-study__block-title">Companions with Purpose</h2>
          <p class="scarlett-case-study__body">
            Each assembled zombie was designed to follow the player and provide a different function during later exploration. This gave collected items a larger purpose, although some companion abilities were not yet fully integrated into the prototype’s core loop.
          </p>
        </div>
      </div>

      <figure class="zompanion-game-design-media" data-zompanion-game-design-media>
        <img
          class="zompanion-game-design-media__img"
          src={images.gameDesignImage}
          alt=""
          loading="lazy"
          decoding="async"
          data-zompanion-game-design-img
        />
      </figure>
    </div>
  </section>

  <section class="scarlett-case-study__section" aria-labelledby="zompanion-game-development">
    <p id="zompanion-game-development" class="scarlett-case-study__section-label">
      GAME DEVELOPMENT
    </p>

    <div class="scarlett-case-study__text-block">
      <h2 class="scarlett-case-study__block-title">
        Building the Core Gameplay Systems
      </h2>
      <p class="scarlett-case-study__body">
        I developed the scene-management, exploration, digging, dialogue, and inventory systems. Together, they supported movement between areas, environmental interaction, item collection, and progression toward zombie assembly.
      </p>
    </div>

    <div class="scarlett-case-study__text-block">
      <h2 class="scarlett-case-study__block-title">
        Managing Interaction and Game States
      </h2>
      <p class="scarlett-case-study__body">
        I implemented interaction feedback and state handling for digging locations, collected items, and companion behaviour. This included preventing repeated actions, maintaining progress between scenes, and keeping the interface consistent with the game’s pixel-art style.
      </p>
    </div>

    <div class="zompanion-game-development-images" data-zompanion-game-development-images>
      {
        zompanionGameDevelopmentImages.map((image) => (
          <figure class="zompanion-game-development-images__item">
            <img
              class="zompanion-game-development-images__img"
              src={image.src}
              alt=""
              loading="lazy"
              decoding="async"
              data-zompanion-game-development-img
              data-placeholder={image.placeholder}
            />
          </figure>
        ))
      }
    </div>

    <div class="scarlett-case-study__subsection">
      <p class="scarlett-case-study__subsection-label">PLAYTESTING</p>

      <h2 class="scarlett-case-study__block-title">Clarifying the Core Loop</h2>
        <p class="scarlett-case-study__body">
              Playtesting showed that the world and visual direction were appealing, but the relationship between exploration, collected items, and zombie functions was not yet clear.
        </p>
        <p class="scarlett-case-study__body">
              Players spent too much time walking between locations, some items lacked an obvious purpose, and the companion system felt separated from the main flow. These findings later became the foundation for rethinking the project’s core loop.
        </p>
        <p class="scarlett-case-study__body">
          Link:{' '}
          <a
            href="https://gggchloe.itch.io/zompanion"
            target="_blank"
            rel="noopener noreferrer"
          >
            https://gggchloe.itch.io/zompanion
          </a>
        </p>
    </div>
  </section>


  <footer class="scarlett-case-study__footer">
    <a class="scarlett-case-study__back" href={backToChapterHref}>← Back to Chapter</a>

    <div class="scarlett-case-study__closing">
      <p class="scarlett-case-study__thanks">
        Thank you for exploring my world! If it resonates, I'd love to hear from you.
      </p>
      <div class="scarlett-case-study__credit">
        <span class="scarlett-case-study__name">Hang Wan</span>
        <span class="scarlett-case-study__credit-dot" aria-hidden="true">·</span>
        <span class="scarlett-case-study__role">Design Playful Experience</span>
        <span class="scarlett-case-study__credit-divider" aria-hidden="true"></span>
        <div class="scarlett-case-study__credit-links">
          <a
            class="scarlett-case-study__credit-link"
            href={`mailto:${contactEmail}`}
            aria-label="Email Hang Wan"
          >
            <img
              class="scarlett-case-study__credit-icon"
              src={aboutContactIcons.gmail}
              alt=""
              width="44"
              height="44"
              loading="lazy"
            />
          </a>
          <a
            class="scarlett-case-study__credit-link"
            href={socialLinks.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
          >
            <img
              class="scarlett-case-study__credit-icon"
              src={aboutContactIcons.linkedin}
              alt=""
              width="44"
              height="44"
              loading="lazy"
            />
          </a>
        </div>
      </div>
    </div>
  </footer>
</article>

<script>
  function syncZompanionHeroImage() {
    const mobileQuery = window.matchMedia('(max-width: 720px)');

    document.querySelectorAll('[data-zompanion-hero-split]').forEach((split) => {
      if (!(split instanceof HTMLElement)) return;

      const copy = split.querySelector('[data-zompanion-hero-copy]');
      const media = split.querySelector('[data-zompanion-hero-media]');
      const img = split.querySelector('[data-zompanion-hero-img]');
      const gifMedia = split.querySelector('[data-zompanion-hero-gif-media]');
      const gif = split.querySelector('[data-zompanion-hero-gif]');

      if (!(copy instanceof HTMLElement) || !(media instanceof HTMLElement) || !(img instanceof HTMLImageElement)) {
        return;
      }

      if (mobileQuery.matches) {
        media.style.height = '';
        media.style.width = '';
        img.style.height = '';
        img.style.width = '';
        if (gifMedia instanceof HTMLElement) {
          gifMedia.style.height = '';
          gifMedia.style.width = '';
        }
        if (gif instanceof HTMLImageElement) {
          gif.style.height = '';
          gif.style.width = '';
        }
        return;
      }

      const copyHeight = Math.round(copy.getBoundingClientRect().height);
      if (copyHeight <= 0) return;

      media.style.height = `${copyHeight}px`;
      media.style.width = 'auto';
      img.style.height = `${copyHeight}px`;
      img.style.width = 'auto';

      const imageHeight = Math.round(img.getBoundingClientRect().height) || copyHeight;

      if (gifMedia instanceof HTMLElement && gif instanceof HTMLImageElement) {
        gifMedia.style.height = `${imageHeight}px`;
        gifMedia.style.width = 'auto';
        gif.style.height = `${imageHeight}px`;
        gif.style.width = 'auto';
      }
    });
  }

  function syncZompanionConceptImages() {
    const mobileQuery = window.matchMedia('(max-width: 720px)');

    document.querySelectorAll('[data-zompanion-concept-row]').forEach((row) => {
      if (!(row instanceof HTMLElement)) return;

      const copy = row.querySelector('[data-zompanion-concept-copy]');
      const imgs = Array.from(row.querySelectorAll('[data-zompanion-concept-img]')).filter(
        (img) => img instanceof HTMLImageElement,
      );

      if (!(copy instanceof HTMLElement) || imgs.length === 0) return;

      if (mobileQuery.matches) {
        imgs.forEach((img) => {
          img.style.height = '';
          img.style.width = '';
        });
        return;
      }

      const copyHeight = Math.round(copy.getBoundingClientRect().height);
      if (copyHeight <= 0) return;

      imgs.forEach((img) => {
        img.style.height = `${copyHeight}px`;
        img.style.width = 'auto';
      });
    });
  }

  function syncZompanionGameDesignImage() {
    const mobileQuery = window.matchMedia('(max-width: 720px)');

    document.querySelectorAll('[data-zompanion-game-design-row]').forEach((row) => {
      if (!(row instanceof HTMLElement)) return;

      const copy = row.querySelector('[data-zompanion-game-design-copy]');
      const media = row.querySelector('[data-zompanion-game-design-media]');
      const img = row.querySelector('[data-zompanion-game-design-img]');

      if (!(copy instanceof HTMLElement) || !(media instanceof HTMLElement) || !(img instanceof HTMLImageElement)) {
        return;
      }

      if (mobileQuery.matches) {
        media.style.height = '';
        media.style.width = '';
        img.style.height = '';
        img.style.width = '';
        return;
      }

      const copyHeight = Math.round(copy.getBoundingClientRect().height);
      if (copyHeight <= 0) return;

      media.style.height = `${copyHeight}px`;
      media.style.width = 'auto';
      img.style.height = `${copyHeight}px`;
      img.style.width = 'auto';
    });
  }

  function syncZompanionGameDevelopmentImages() {
    const mobileQuery = window.matchMedia('(max-width: 720px)');

    document.querySelectorAll('[data-zompanion-game-development-images]').forEach((row) => {
      if (!(row instanceof HTMLElement)) return;

      const items = Array.from(row.querySelectorAll('.zompanion-game-development-images__item')).filter(
        (item) => item instanceof HTMLElement,
      );
      const imgs = Array.from(row.querySelectorAll('[data-zompanion-game-development-img]')).filter(
        (img) => img instanceof HTMLImageElement,
      );

      if (items.length === 0 || imgs.length === 0 || items.length !== imgs.length) return;

      if (mobileQuery.matches) {
        items.forEach((item) => {
          item.style.width = '';
          item.style.height = '';
        });
        imgs.forEach((img) => {
          img.style.width = '';
          img.style.height = '';
        });
        return;
      }

      const ratios = imgs.map((img) => {
        if (img.naturalWidth <= 0 || img.naturalHeight <= 0) return null;
        return img.naturalWidth / img.naturalHeight;
      });

      if (ratios.some((ratio) => ratio === null)) return;

      const gap = Number.parseFloat(getComputedStyle(row).columnGap || getComputedStyle(row).gap) || 0;
      const availableWidth = row.getBoundingClientRect().width - gap * Math.max(0, imgs.length - 1);
      if (availableWidth <= 0) return;

      const ratioSum = ratios.reduce((sum, ratio) => sum + (ratio ?? 0), 0);
      if (ratioSum <= 0) return;

      const sharedHeight = Math.round(availableWidth / ratioSum);

      imgs.forEach((img, index) => {
        const ratio = ratios[index];
        if (ratio === null) return;
        const width = Math.round(sharedHeight * ratio);
        img.style.height = `${sharedHeight}px`;
        img.style.width = `${width}px`;
        items[index].style.height = `${sharedHeight}px`;
        items[index].style.width = `${width}px`;
      });
    });
  }

  function bindZompanionHeroSync() {
    const mobileQuery = window.matchMedia('(max-width: 720px)');

    document.querySelectorAll('[data-zompanion-hero-copy]').forEach((copy) => {
      if (!(copy instanceof HTMLElement) || copy.dataset.heroObserverBound === 'true') return;
      copy.dataset.heroObserverBound = 'true';

      const observer = new ResizeObserver(() => {
        if (!mobileQuery.matches) syncZompanionHeroImage();
      });
      observer.observe(copy);
    });

    document.querySelectorAll('[data-zompanion-hero-img], [data-zompanion-hero-gif]').forEach((img) => {
      if (!(img instanceof HTMLImageElement) || img.dataset.heroLoadBound === 'true') return;
      img.dataset.heroLoadBound = 'true';
      img.addEventListener('load', syncZompanionHeroImage);
      if (img.complete && img.naturalWidth > 0) syncZompanionHeroImage();
    });
  }

  function bindZompanionConceptSync() {
    const mobileQuery = window.matchMedia('(max-width: 720px)');

    document.querySelectorAll('[data-zompanion-concept-copy]').forEach((copy) => {
      if (!(copy instanceof HTMLElement) || copy.dataset.conceptObserverBound === 'true') return;
      copy.dataset.conceptObserverBound = 'true';

      const observer = new ResizeObserver(() => {
        if (!mobileQuery.matches) syncZompanionConceptImages();
      });
      observer.observe(copy);
    });

    document.querySelectorAll('[data-zompanion-concept-img]').forEach((img) => {
      if (!(img instanceof HTMLImageElement) || img.dataset.conceptLoadBound === 'true') return;
      img.dataset.conceptLoadBound = 'true';
      img.addEventListener('load', syncZompanionConceptImages);
      if (img.complete && img.naturalWidth > 0) syncZompanionConceptImages();
    });
  }

  function bindZompanionGameDesignSync() {
    const mobileQuery = window.matchMedia('(max-width: 720px)');

    document.querySelectorAll('[data-zompanion-game-design-copy]').forEach((copy) => {
      if (!(copy instanceof HTMLElement) || copy.dataset.gameDesignObserverBound === 'true') return;
      copy.dataset.gameDesignObserverBound = 'true';

      const observer = new ResizeObserver(() => {
        if (!mobileQuery.matches) syncZompanionGameDesignImage();
      });
      observer.observe(copy);
    });

    document.querySelectorAll('[data-zompanion-game-design-img]').forEach((img) => {
      if (!(img instanceof HTMLImageElement) || img.dataset.gameDesignLoadBound === 'true') return;
      img.dataset.gameDesignLoadBound = 'true';
      img.addEventListener('load', syncZompanionGameDesignImage);
      if (img.complete && img.naturalWidth > 0) syncZompanionGameDesignImage();
    });
  }

  function bindZompanionGameDevelopmentSync() {
    const mobileQuery = window.matchMedia('(max-width: 720px)');

    document.querySelectorAll('[data-zompanion-game-development-images]').forEach((row) => {
      if (!(row instanceof HTMLElement) || row.dataset.gameDevelopmentObserverBound === 'true') return;
      row.dataset.gameDevelopmentObserverBound = 'true';

      const observer = new ResizeObserver(() => {
        if (!mobileQuery.matches) syncZompanionGameDevelopmentImages();
      });
      observer.observe(row);
    });

    document.querySelectorAll('[data-zompanion-game-development-img]').forEach((img) => {
      if (!(img instanceof HTMLImageElement) || img.dataset.gameDevelopmentLoadBound === 'true') return;
      img.dataset.gameDevelopmentLoadBound = 'true';
      img.addEventListener('load', syncZompanionGameDevelopmentImages);
      if (img.complete && img.naturalWidth > 0) syncZompanionGameDevelopmentImages();
    });
  }

  function syncZompanionLayouts() {
    syncZompanionHeroImage();
    syncZompanionConceptImages();
    syncZompanionGameDesignImage();
    syncZompanionGameDevelopmentImages();
  }

  function initZompanionCaseStudy() {
    bindZompanionHeroSync();
    bindZompanionConceptSync();
    bindZompanionGameDesignSync();
    bindZompanionGameDevelopmentSync();
    syncZompanionLayouts();
  }

  initZompanionCaseStudy();
  document.addEventListener('astro:page-load', initZompanionCaseStudy);
  window.addEventListener('resize', syncZompanionLayouts);
</script>
