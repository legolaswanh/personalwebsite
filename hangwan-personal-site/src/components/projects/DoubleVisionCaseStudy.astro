---
import CaseStudyMedia from './CaseStudyMedia.astro';
import CaseStudyVideo from './CaseStudyVideo.astro';
import {
  doubleVisionCaseStudyImages,
  doubleVisionDemoVideoId,
  doubleVisionStateMachineVideos,
  doubleVisionStateOverviewImages,
} from '../../data/doubleVisionCaseStudy';
import { aboutContactIcons } from '../../data/aboutAssets';
import { contactEmail, socialLinks } from '../../data/aboutContent';

const images = doubleVisionCaseStudyImages;
const embedUrl = `https://www.youtube-nocookie.com/embed/${doubleVisionDemoVideoId}?rel=0&modestbranding=1&playsinline=1`;
const backToChapterHref = '/?highlight=double-vision#chapter-1';
---

<article class="scarlett-case-study double-vision-case-study">
  <header class="scarlett-case-study__hero">
    <p class="scarlett-case-study__project-name">Double Vision</p>
    <h1 class="scarlett-case-study__hero-title">
      A <strong>narrative mystery</strong> about perception, evidence, and the distance between what can be recorded and what can only be sensed.
    </h1>
    <CaseStudyMedia
      class="double-vision-case-study__hero-banner scarlett-case-study__transparent-media"
      src={images.hero}
      alt=""
      placeholder="Double Vision hero"
      fit="contain"
    />
    <p class="scarlett-case-study__body">
      Playing as a medium detective, players investigate a present-day disappearance linked to a death that was closed two years earlier. Cameras, documents, and supernatural traces reveal different fragments of the same truth.
    </p>
  </header>

  <section class="scarlett-case-study__section" aria-labelledby="double-vision-inspiration">
    <p id="double-vision-inspiration" class="scarlett-case-study__section-label">INSPIRATION</p>

    <div class="double-vision-case-study__inspiration-row">
      <CaseStudyMedia
        class="double-vision-case-study__inspiration-image scarlett-case-study__transparent-media"
        src={images.inspirationImage}
        alt=""
        placeholder="Inspiration image"
        fit="contain"
      />
      <div class="scarlett-case-study__text-block double-vision-case-study__inspiration-copy">
        <h2 class="scarlett-case-study__block-title">Between Two Ways of Seeing</h2>
        <p class="scarlett-case-study__body">
          Drawing on the Chinese folklore of "Yin–Yang Eyes," Double Vision contrasts supernatural perception with modern surveillance technology. Neither perspective is complete: players must move between recorded evidence and invisible traces to reconstruct what happened.
        </p>
      </div>
    </div>
  </section>

  <section class="scarlett-case-study__section" aria-labelledby="double-vision-inspiration">
    <p id="double-vision-inspiration" class="scarlett-case-study__section-label">NARRATIVE DESIGN</p>

    <div class="double-vision-case-study__narrative-layout">
      <h2 class="scarlett-case-study__block-title double-vision-case-study__narrative-title">Storytelling Arc</h2>
      <p class="scarlett-case-study__body double-vision-case-study__narrative-intro">
        Double Vision follows a three-act structure built around two intertwined cases: Zhuang's disappearance and Lin Anan's death. Exploration, contradiction, and revelation steadily raise the stakes, while the player's interpretation of evidence determines how much of the truth is ultimately uncovered.
      </p>

      <div class="double-vision-case-study__narrative-arc-side double-vision-case-study__narrative-arc-side--act-1">
        <p class="double-vision-case-study__narrative-arc-act-label">Act 1</p>
        <div class="double-vision-case-study__narrative-arc-beats">
          <div class="scarlett-case-study__rule-copy">
            <p class="scarlett-case-study__rule-title">01  The Hook</p>
            <p class="scarlett-case-study__rule-title">The missing case</p>
            <p class="scarlett-case-study__rule-body">A question that draws players into the game story.</p>
          </div>
          <div class="scarlett-case-study__rule-copy">
            <p class="scarlett-case-study__rule-title">02  Inciting Event</p>
            <p class="scarlett-case-study__rule-title">Inciting Event</p>
            <p class="scarlett-case-study__rule-body">An event that sets the narrative in motion.</p>
          </div>
          <div class="scarlett-case-study__rule-copy">
            <p class="scarlett-case-study__rule-title">03  1st Plot Point</p>
            <p class="scarlett-case-study__rule-title">Relating two cases</p>
            <p class="scarlett-case-study__rule-body">A point of no return.</p>
          </div>
        </div>
      </div>

      <CaseStudyMedia
        class="double-vision-case-study__narrative-arc-media scarlett-case-study__transparent-media"
        src={images.narrativeDesign}
        alt=""
        placeholder="Storytelling arc diagram"
        fit="contain"
      />

      <div class="double-vision-case-study__narrative-arc-bottom">
        <div class="double-vision-case-study__narrative-arc-act-block">
          <p class="double-vision-case-study__narrative-arc-act-label">Act 2</p>
          <div class="double-vision-case-study__narrative-arc-beats double-vision-case-study__narrative-arc-beats--horizontal">
            <div class="scarlett-case-study__rule-copy">
              <p class="scarlett-case-study__rule-title">04  1st Pinch Point</p>
              <p class="scarlett-case-study__rule-title">Sensing the villain</p>
              <p class="scarlett-case-study__rule-body">A subtle moment that shows the antagonistic force.</p>
            </div>
            <div class="scarlett-case-study__rule-copy">
              <p class="scarlett-case-study__rule-title">05  MidPoint</p>
              <p class="scarlett-case-study__rule-title">Revealing relationship</p>
              <p class="scarlett-case-study__rule-body">A big moment of plot conflict.</p>
            </div>
            <div class="scarlett-case-study__rule-copy">
              <p class="scarlett-case-study__rule-title">06  2nd Pinch Point</p>
              <p class="scarlett-case-study__rule-title">Clues of shady dealings</p>
              <p class="scarlett-case-study__rule-body">A tension moment that stakes are higher then eve.</p>
            </div>
          </div>
        </div>

        <div class="double-vision-case-study__narrative-arc-act-block">
          <p class="double-vision-case-study__narrative-arc-act-label">Act 3</p>
          <div class="double-vision-case-study__narrative-arc-beats double-vision-case-study__narrative-arc-beats--horizontal">
            <div class="scarlett-case-study__rule-copy">
              <p class="scarlett-case-study__rule-title">07  3rd Plot Point</p>
              <p class="scarlett-case-study__rule-title">The truth about Death</p>
              <p class="scarlett-case-study__rule-body">A "false" victory leads the story into its final act.</p>
            </div>
            <div class="scarlett-case-study__rule-copy">
              <p class="scarlett-case-study__rule-title">08  Climax</p>
              <p class="scarlett-case-study__rule-title">Revealing the truth</p>
              <p class="scarlett-case-study__rule-body">A final turning point.</p>
            </div>
            <div class="scarlett-case-study__rule-copy">
              <p class="scarlett-case-study__rule-title">09  Denouement</p>
              <p class="scarlett-case-study__rule-title">Multiple endings</p>
              <p class="scarlett-case-study__rule-body">An outcome of decisions.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="double-vision-case-study__outcomes">
        <h2 class="scarlett-case-study__block-title double-vision-case-study__outcomes-title">
          The Ultimate Outcomes
        </h2>
        <div class="double-vision-case-study__outcomes-row">
          <div class="double-vision-case-study__outcomes-media">
            <CaseStudyMedia
              class="double-vision-case-study__outcomes-image scarlett-case-study__transparent-media"
              src={images.narrativeDesignOutcome1}
              alt=""
              placeholder="Outcome diagram 1"
              fit="contain"
            />
            <CaseStudyMedia
              class="double-vision-case-study__outcomes-image scarlett-case-study__transparent-media"
              src={images.narrativeDesignOutcome2}
              alt=""
              placeholder="Outcome diagram 2"
              fit="contain"
            />
          </div>
          <p class="scarlett-case-study__body double-vision-case-study__outcomes-copy">
            Each ending reflects both what the player uncovers and how they choose to pursue justice. Complete reasoning reveals the full connection between the two cases, while missing or misinterpreting key evidence leads to partial, distorted, or morally compromised outcomes.
          </p>
        </div>
      </div>

    </div>
  </section>

  <section class="scarlett-case-study__section" aria-labelledby="double-vision-game-design">
    <p id="double-vision-game-design" class="scarlett-case-study__section-label">GAME DESIGN</p>

    <div class="scarlett-case-study__stack">
      <div class="double-vision-case-study__evidence">
        <h2 class="scarlett-case-study__block-title double-vision-case-study__evidence-title">
          Investigating Through Two Forms of Evidence
        </h2>
        <div class="double-vision-case-study__evidence-row">
          <p class="scarlett-case-study__body double-vision-case-study__evidence-copy">
            One mode examines cameras, documents, and physical evidence; the other reveals supernatural traces left by past events. Switching between them exposes contradictions and hidden connections that neither perspective can reveal alone.
          </p>
          <CaseStudyMedia
            class="double-vision-case-study__evidence-image scarlett-case-study__transparent-media"
            src={images.gameDesignImage1}
            alt=""
            placeholder="Two forms of evidence"
            fit="contain"
          />
        </div>
      </div>

      <div class="double-vision-case-study__reasoning">
        <div class="scarlett-case-study__text-block">
          <h2 class="scarlett-case-study__block-title">Reasoning Through Contradiction</h2>
          <p class="scarlett-case-study__body">
            Players collect clues, assess their reliability, and connect them into chains of causality. New evidence can challenge earlier hypotheses, requiring players to revise their interpretation before reaching a conclusion.
          </p>
        </div>
        <div class="double-vision-case-study__reasoning-gallery">
          <CaseStudyMedia
            class="double-vision-case-study__reasoning-image double-vision-case-study__reasoning-image--2 scarlett-case-study__transparent-media"
            src={images.gameDesignImage2}
            alt=""
            placeholder="Reasoning diagram 1"
            fit="contain"
          />
          <CaseStudyMedia
            class="double-vision-case-study__reasoning-image double-vision-case-study__reasoning-image--3 scarlett-case-study__transparent-media"
            src={images.gameDesignImage3}
            alt=""
            placeholder="Reasoning diagram 2"
            fit="contain"
          />
          <CaseStudyMedia
            class="double-vision-case-study__reasoning-image double-vision-case-study__reasoning-image--4 scarlett-case-study__transparent-media"
            src={images.gameDesignImage4}
            alt=""
            placeholder="Reasoning diagram 3"
            fit="contain"
          />
        </div>
      </div>

      <div class="scarlett-case-study__text-block">
        <h2 class="scarlett-case-study__block-title">Spaces of Gradual Revelation</h2>
        <p class="scarlett-case-study__body">
          Each location functions as a compact investigation space, layering environmental evidence, supernatural traces, and new contradictions. The sequence of spaces controls the rhythm of discovery, moving players from uncertainty toward recognition.
        </p>
      </div>
    </div>
  </section>

  <footer class="scarlett-case-study__footer">
    <a class="scarlett-case-study__back" href={backToChapterHref}>← Back to Chapter</a>

    <div class="scarlett-case-study__closing">
      <p class="scarlett-case-study__thanks">
        Thank you for exploring my world! If it resonates, I'd love to hear from you.
      </p>
      <div class="scarlett-case-study__credit">
        <span class="scarlett-case-study__name">Hang Wan</span>
        <span class="scarlett-case-study__credit-dot" aria-hidden="true">·</span>
        <span class="scarlett-case-study__role">Design Playful Experience</span>
        <span class="scarlett-case-study__credit-divider" aria-hidden="true"></span>
        <div class="scarlett-case-study__credit-links">
          <a
            class="scarlett-case-study__credit-link"
            href={`mailto:${contactEmail}`}
            aria-label="Email Hang Wan"
          >
            <img
              class="scarlett-case-study__credit-icon"
              src={aboutContactIcons.gmail}
              alt=""
              width="44"
              height="44"
              loading="lazy"
            />
          </a>
          <a
            class="scarlett-case-study__credit-link"
            href={socialLinks.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
          >
            <img
              class="scarlett-case-study__credit-icon"
              src={aboutContactIcons.linkedin}
              alt=""
              width="44"
              height="44"
              loading="lazy"
            />
          </a>
        </div>
      </div>
    </div>
  </footer>
</article>

<script>
  function initCaseStudyMedia() {
    document.querySelectorAll('[data-case-study-img]').forEach((img) => {
      if (!(img instanceof HTMLImageElement) || img.dataset.mediaBound === 'true') return;
      img.dataset.mediaBound = 'true';

      const markMissing = () => {
        const figure = img.closest('[data-case-study-media]');
        figure?.classList.add('is-missing');
      };

      img.addEventListener('error', markMissing);
      if (img.complete && img.naturalWidth === 0) markMissing();
    });

    document.querySelectorAll('[data-case-study-video]').forEach((video) => {
      if (!(video instanceof HTMLVideoElement) || video.dataset.mediaBound === 'true') return;
      video.dataset.mediaBound = 'true';

      const markMissing = () => {
        const figure = video.closest('[data-case-study-media]');
        figure?.classList.add('is-missing');
      };

      video.addEventListener('error', markMissing);
    });
  }

  initCaseStudyMedia();
  document.addEventListener('astro:page-load', initCaseStudyMedia);
</script>
