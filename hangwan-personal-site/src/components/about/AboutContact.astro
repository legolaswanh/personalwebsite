---
import { contactEmail, socialLinks } from '../../data/aboutContent';
import { aboutContactIcons } from '../../data/aboutAssets';

const socialItems = [
  { id: 'linkedin', label: 'LinkedIn', href: socialLinks.linkedin },
  { id: 'instagram', label: 'Instagram', href: socialLinks.instagram },
  { id: 'facebook', label: 'Facebook', href: socialLinks.facebook },
] as const;
---

<section class="about-section about-contact" aria-labelledby="about-contact-thanks">
  <div class="about-contact__inner">
    <div class="about-contact__text-block">
      <div class="about-contact__messages">
        <p id="about-contact-thanks" class="about-contact__thanks">
          Thank you for exploring my world!
        </p>
        <p class="about-contact__headline">Open to work and thoughtful collaboration.</p>
      </div>
    </div>

    <div class="about-contact__links-wrap">
      <hr class="about-contact__rule" aria-hidden="true" />

      <div class="about-contact__bar">
        <div class="about-contact__lead-group">
          <p class="about-contact__label">Contact me!</p>
          <a class="about-contact__email" href={`mailto:${contactEmail}`}>
            <img
              class="about-contact__icon about-contact__icon--email"
              src={aboutContactIcons.gmail}
              alt=""
              width="44"
              height="44"
              loading="lazy"
            />
            <span>{contactEmail}</span>
          </a>
        </div>

        <span class="about-contact__vrule" aria-hidden="true"></span>

        <div class="about-contact__socials">
          {
            socialItems.map((item) => (
              <a
                class="about-contact__social"
                href={item.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={item.label}
              >
                <img
                  class:list={[
                    'about-contact__icon',
                    'about-contact__icon--social',
                    item.id === 'facebook' && 'about-contact__icon--native',
                  ]}
                  src={aboutContactIcons[item.id]}
                  alt=""
                  width="44"
                  height="44"
                  loading="lazy"
                />
              </a>
            ))
          }
        </div>

        <span class="about-contact__vrule" aria-hidden="true"></span>

        <div class="about-contact__credit">
          <span class="about-contact__handle">@Hang Wan</span>
          <span class="about-contact__year">2026</span>
        </div>
      </div>
    </div>
  </div>
</section>
