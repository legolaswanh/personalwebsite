---
import type { ChapterProject } from '../../types/chapterProject';
import { projectCoverImage } from '../../utils/chapterGallery';

interface Props {
  projects: ChapterProject[];
  activeId: string;
  heading?: string;
}

const {
  projects,
  activeId,
  heading = 'Selected Works',
} = Astro.props;
---

<div class="chapter-rail-wrap chapter-rail-wrap--cards">
  <div class="chapter-rail__header">
    <h3 class="chapter-rail__heading">{heading}</h3>
    <span class="chapter-rail__rule" aria-hidden="true"></span>
  </div>

  <div class="chapter-rail chapter-rail--cards" role="list" data-chapter-rail>
    {projects.map((project, index) => (
      <>
        {index > 0 && (
          <span class="chapter-rail__spacer" aria-hidden="true">
            <span class="chapter-rail__divider"></span>
          </span>
        )}
        {project.railDisabled ? (
          <div
            class="chapter-rail__item chapter-rail__item--disabled"
            role="listitem"
            aria-disabled="true"
          >
            <span class="chapter-rail__card">
              <span class="chapter-rail__thumb" data-asset-wrap>
                <img
                  class="chapter-rail__thumb-img"
                  src={projectCoverImage(project.images)}
                  alt=""
                  loading="lazy"
                  decoding="async"
                  data-asset-image
                />
                <span class="chapter-rail__thumb-fallback" aria-hidden="true">
                  {project.title.charAt(0)}
                </span>
              </span>
              <span class="chapter-rail__text">
                <span class="chapter-rail__title">{project.title}</span>
                <span class="chapter-rail__focus chapter-rail__focus--static">
                  {project.focusLabel}
                </span>
              </span>
            </span>
          </div>
        ) : (
          <button
            type="button"
            class:list={[
              'chapter-rail__item',
              project.id === activeId && 'is-active',
            ]}
            role="listitem"
            data-project-id={project.id}
            aria-pressed={project.id === activeId ? 'true' : 'false'}
            aria-label={`Show ${project.title}`}
          >
            <span class="chapter-rail__card">
              <span class="chapter-rail__thumb" data-asset-wrap>
                <img
                  class="chapter-rail__thumb-img"
                  src={projectCoverImage(project.images)}
                  alt=""
                  loading="lazy"
                  decoding="async"
                  data-asset-image
                />
                <span class="chapter-rail__thumb-fallback" aria-hidden="true">
                  {project.title.charAt(0)}
                </span>
              </span>
              <span class="chapter-rail__text">
                <span class="chapter-rail__title">{project.title}</span>
                <span class="chapter-rail__focus">{project.focusLabel}</span>
              </span>
            </span>
          </button>
        )}
      </>
    ))}
  </div>
</div>
