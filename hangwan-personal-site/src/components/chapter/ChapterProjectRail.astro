---
import type { ChapterProject } from '../../types/chapterProject';

interface Props {
  projects: ChapterProject[];
  activeId: string;
  heading?: string;
}

const {
  projects,
  activeId,
  heading = 'Selected Works',
} = Astro.props;
---

<div class="chapter-rail-wrap">
  <div class="chapter-rail__header">
    <h3 class="chapter-rail__heading">{heading}</h3>
    <span class="chapter-rail__rule" aria-hidden="true"></span>
  </div>

  <div class="chapter-rail" role="list" data-chapter-rail>
    {projects.map((project, index) => (
      <>
        {index > 0 && <span class="chapter-rail__divider" aria-hidden="true"></span>}
        <button
          type="button"
          class:list={[
            'chapter-rail__item',
            project.id === activeId && 'is-active',
          ]}
          role="listitem"
          data-project-id={project.id}
          aria-pressed={project.id === activeId ? 'true' : 'false'}
          aria-label={`Show ${project.title}`}
        >
          <span class="chapter-rail__thumb" data-asset-wrap>
            <img
              class="chapter-rail__thumb-img"
              src={project.images.coverImage}
              alt=""
              loading="lazy"
              decoding="async"
              data-asset-image
            />
            <span class="chapter-rail__thumb-fallback" aria-hidden="true">
              {project.title.charAt(0)}
            </span>
          </span>
          <span class="chapter-rail__text">
            <span class="chapter-rail__title">{project.title}</span>
            <span class="chapter-rail__focus">{project.focusLabel}</span>
          </span>
        </button>
      </>
    ))}
  </div>
</div>
