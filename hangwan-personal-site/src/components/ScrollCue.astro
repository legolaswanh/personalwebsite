<button
  type="button"
  class="scroll-cue"
  aria-label="Scroll to Chapter 1"
  data-target="#chapter-1"
>
  <span class="scroll-cue__label">View Projects</span>
  <span class="scroll-cue__chevron" aria-hidden="true"></span>
</button>

<script>
  import { scrollToHomeSection } from '../scripts/homeSectionHash';

  function initScrollCue() {
    const button = document.querySelector('.scroll-cue');
    if (!(button instanceof HTMLButtonElement)) return;

    button.addEventListener('click', () => {
      scrollToHomeSection('#chapter-1');
    });
  }

  initScrollCue();
  document.addEventListener('astro:page-load', initScrollCue);
</script>
