---
import ChapterHeader from '../chapter/ChapterHeader.astro';
import ChapterShowcase from '../chapter/ChapterShowcase.astro';
import ChapterProjectRail from '../chapter/ChapterProjectRail.astro';
import {
  gamesChapterConfig,
  gamesProjects,
  gamesDefaultProject,
} from '../../data/gamesProjects';
import { CHAPTER_DEFAULT_CTA_LABEL } from '../../types/chapterProject';
---

<section
  id="chapter-1"
  class="page-section chapter-page games-section"
  data-chapter-page
  data-default-project={gamesDefaultProject.id}
  data-default-cta-label={CHAPTER_DEFAULT_CTA_LABEL}
>
  <div class="section-inner chapter-page-section-inner">
    <div class="chapter-page__frame container">
      <ChapterHeader chapter={gamesChapterConfig} />

      <div class="chapter-page__body">
        <div class="chapter-page__stage">
          <ChapterShowcase project={gamesDefaultProject} />
        </div>
        <ChapterProjectRail
          projects={gamesProjects}
          activeId={gamesDefaultProject.id}
        />
      </div>
    </div>
  </div>

  <script
    type="application/json"
    data-chapter-projects
    set:html={JSON.stringify(gamesProjects)}
  />
</section>

<script>
  import { initChapterShowcase, initChapterHighlightFromUrl } from '../../scripts/chapterShowcase';
  import { initGamesChapterGallery } from '../../scripts/gamesChapterGallery';
  import { initChapterToolsAlign } from '../../scripts/alignIxdTools';
  import { initChapterLayout } from '../../scripts/chapterLayout';

  function initGamesSection() {
    initChapterShowcase();
    initGamesChapterGallery();
    initChapterToolsAlign();
    initChapterLayout();
    initChapterHighlightFromUrl();
  }

  initGamesSection();
  document.addEventListener('astro:page-load', initGamesSection);
</script>
