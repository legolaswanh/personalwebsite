---
import ChapterHeader from '../chapter/ChapterHeader.astro';
import ChapterShowcase from '../chapter/ChapterShowcase.astro';
import ChapterProjectRail from '../chapter/ChapterProjectRail.astro';
import {
  researchChapterConfig,
  researchProjects,
  researchDefaultProject,
} from '../../data/researchProjects';
---

<section
  id="chapter-3"
  class="page-section chapter-page research-section"
  data-chapter-page
  data-default-project={researchDefaultProject.id}
>
  <div class="section-inner chapter-page-section-inner">
    <div class="chapter-page__frame container">
      <ChapterHeader chapter={researchChapterConfig} />

      <div class="chapter-page__body">
        <div class="chapter-page__stage">
          <ChapterShowcase
            project={researchDefaultProject}
            ctaLabel={researchChapterConfig.ctaLabel}
          />
        </div>
        <ChapterProjectRail
          projects={researchProjects}
          activeId={researchDefaultProject.id}
        />
      </div>
    </div>
  </div>

  <script
    type="application/json"
    data-chapter-projects
    set:html={JSON.stringify(researchProjects)}
  />
</section>

<script>
  import { initChapterShowcase } from '../../scripts/chapterShowcase';
  import { initGamesChapterGallery } from '../../scripts/gamesChapterGallery';

  function initDesignResearchSection() {
    initChapterShowcase();
    initGamesChapterGallery();
  }

  initDesignResearchSection();
  document.addEventListener('astro:page-load', initDesignResearchSection);
</script>
