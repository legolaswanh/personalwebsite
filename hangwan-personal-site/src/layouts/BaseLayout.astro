---
import '../styles/global.css';
import SiteNav from '../components/SiteNav.astro';
import CursorGlow from '../components/CursorGlow.astro';

interface Props {
  title?: string;
  description?: string;
  showNav?: boolean;
  isHome?: boolean;
  bodyClass?: string;
}

const {
  title = 'Hang Wan — Personal Website',
  description = 'A personal archive of interaction design, game design, public installations, and research-based projects by Hang Wan.',
  showNav = true,
  isHome = false,
  bodyClass,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body
    class:list={{
      'is-home': isHome,
      [bodyClass ?? '']: Boolean(bodyClass),
    }}
  >
    <CursorGlow />
    {showNav && <SiteNav />}

    {isHome ? (
      <slot />
    ) : (
      <main>
        <slot />
      </main>
    )}
  </body>
</html>
